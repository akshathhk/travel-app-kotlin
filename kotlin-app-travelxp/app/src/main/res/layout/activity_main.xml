<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:background="@color/surface"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivHero"
        android:layout_width="0dp"
        android:layout_height="115dp"
        android:scaleType="centerCrop"
        android:src="@drawable/travelxp"
        android:background="@drawable/card"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Log places, dates, ratings, and memories."
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/ink"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/ivHero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnAddTrip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Add Trip"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnViewTrips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="View Trips"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnAddTrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnAbout"
        style="@style/Widget.TravelXP.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="About"
        android:textColor="@color/cream"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnViewTrips"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnLogin"
        style="@style/Widget.TravelXP.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Login / Register"
        android:textColor="@color/cream"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnAbout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnSignOut"
        style="@style/Widget.TravelXP.Button.Danger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sign Out"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
