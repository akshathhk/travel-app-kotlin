<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Add Trip"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/ink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etPlaceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Place name"
            android:inputType="textPersonName"
            android:layout_marginTop="12dp"
            android:background="@drawable/card"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvRatingLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Rating"
            android:textStyle="bold"
            android:textColor="@color/ink_soft"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/etPlaceName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="1"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvRatingLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btnPickStartDate"
            style="@style/Widget.TravelXP.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pick Start Date"
            android:textColor="@color/cream"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/ratingBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnPickEndDate"
            style="@style/Widget.TravelXP.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Pick End Date"
            android:textColor="@color/cream"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@+id/btnPickStartDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etWith"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Traveled with (optional)"
            android:layout_marginTop="12dp"
            android:background="@drawable/card"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@+id/btnPickEndDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Notes"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="12dp"
            android:background="@drawable/card"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/etWith"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/etNotes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnClearDraft"
            style="@style/Widget.TravelXP.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Clear Draft"
            android:textColor="@color/cream"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnSave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
