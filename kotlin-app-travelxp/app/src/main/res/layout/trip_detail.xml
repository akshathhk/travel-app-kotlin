<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:background="@color/cream"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ivType"
        android:layout_width="100dp"
        android:layout_height="84dp"
        android:src="@drawable/travelimage"
        android:scaleType="centerCrop"
        android:background="@drawable/card"
        android:clipToOutline="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPlace"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Place"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/ink"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/ivType"
        app:layout_constraintTop_toTopOf="@id/ivType"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="@color/ink_soft"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/ivType"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvRating"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Rating"
        android:textColor="@color/gold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvWith"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="With"
        android:textColor="@color/ink_soft"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvRating"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvNotes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="Notes"
        android:textColor="@color/ink"
        android:layout_marginTop="12dp"
        android:background="@drawable/card"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@+id/tvWith"
        app:layout_constraintBottom_toTopOf="@id/btnEdit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnEdit"
        style="@style/Widget.TravelXP.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Edit"
        android:textColor="@color/cream"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDelete"
        app:layout_constraintWidth_percent="0.48"/>

    <Button
        android:id="@+id/btnDelete"
        style="@style/Widget.TravelXP.Button.Danger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Delete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnEdit"
        app:layout_constraintWidth_percent="0.48"/>
</androidx.constraintlayout.widget.ConstraintLayout>
